{
  "name": "ernilambar/dashkit",
  "description": "Reusable widget engine for WordPress admin pages.",
  "license": "GPL-2.0-or-later",
  "type": "library",
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1",
    "ernilambar/coding-standard": "^1",
    "php-parallel-lint/php-parallel-lint": "^1",
    "slevomat/coding-standard": "^8",
    "wp-cli/i18n-command": "^2",
    "wp-cli/wp-cli": "^2",
    "wp-coding-standards/wpcs": "^3.3"
  },
  "autoload": {
    "psr-4": {
      "Nilambar\\Dashkit\\": "src/"
    }
  },
  "scripts": {
    "format": "@php ./vendor/bin/phpcbf --report-full --report-summary",
    "lint": [
      "@lint-php",
      "@phpcs"
    ],
    "lint-php": "@php ./vendor/bin/parallel-lint -p php --colors --exclude .git --exclude vendor .",
    "make-mo": "./vendor/bin/wp i18n make-mo languages/",
    "phpcs": "@php ./vendor/bin/phpcs --report-full --report-summary",
    "pot": "./vendor/bin/wp i18n make-pot . --exclude=assets,node_modules,third-party,vendor --headers='{\"POT-Creation-Date\":\"\"}'",
    "update-po": "./vendor/bin/wp i18n update-po dashkit.pot languages/"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "ergebnis/composer-normalize": true
    },
    "optimize-autoloader": true,
    "platform": {
      "php": "8.0"
    },
    "sort-packages": true
  }
}
