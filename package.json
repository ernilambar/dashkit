{
	"name": "dashkit",
	"version": "1.0.0",
	"description": "Reusable widget engine for WordPress admin pages.",
	"author": "Nilambar Sharma",
	"license": "GPL-2.0-or-later",
	"homepage": "https://github.com/ernilambar/dashkit",
	"repository": {
		"type": "git",
		"url": "https://github.com/ernilambar/dashkit.git"
	},
