{
	"name": "ernilambar/dashkit",
	"description": "Reusable widget engine for WordPress admin pages.",
	"license": "GPL-2.0-or-later",
	"type": "library",
	"require": {
		"php": ">=8.0"
	},
	"autoload": {
		"psr-4": {
			"Nilambar\\Dashkit\\": "src/"
		}
	},
	"config": {
		"optimize-autoloader": true,
		"platform": {
			"php": "8.0"
		},
		"sort-packages": true
	}
}
